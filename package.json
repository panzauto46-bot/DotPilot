{
  "name": "dotpilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:api": "node --env-file-if-exists=.env server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node --env-file-if-exists=.env server/index.mjs",
    "contracts:compile": "node scripts/compile-contracts.mjs",
