    "recharts": "^3.8.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "ethers": "^6.16.0",
    "ganache": "^7.9.2",
    "solc": "^0.8.34",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
